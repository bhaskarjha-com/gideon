#!/usr/bin/env bash
# gideon — One command. All identities. Every machine.
#
# A zero-dependency CLI tool for automated Git multi-identity
# and SSH key setup. Clone, run, done.
#
# Usage: ./gideon setup [--dry-run]
#        ./gideon status
#        ./gideon verify
#        ./gideon guard --install | --uninstall
#        ./gideon --help | --version
#
# https://github.com/bhaskarjha-com/gideon
# MIT License — Bhaskar Jha

# --- CRLF self-healing for VirtualBox shared folders ---
# vboxsf injects \r into all files. Unconditionally re-exec through tr on first run.
# tr -d '\r' is a no-op on clean files, so this is safe everywhere.
if ! command -v tr >/dev/null 2>&1; then echo "Error: 'tr' command is required but not found." >&2; exit 1; fi
# shellcheck disable=SC2270
test "${GIDEON_CRLF_CLEAN:-}" = "1" || { export GIDEON_CRLF_CLEAN=1; export GIDEON_ORIG_SCRIPT="${BASH_SOURCE[0]:-$0}"; exec bash <(tr -d '\r' < "${BASH_SOURCE[0]:-$0}") "$@"; }

set -euo pipefail

# ------------------------------------------------------------------------------
# Resolve script directory (handles symlinks, $0 fallback, vboxsf CRLF re-exec)
# ------------------------------------------------------------------------------
resolve_script_dir() {
    # When re-executed for CRLF cleaning, BASH_SOURCE is /dev/fd/N.
    # Use GIDEON_ORIG_SCRIPT (set before re-exec) to find the real script.
    # Strip \r because the env var was set from a CRLF-contaminated line.
    local source
    source=$(printf '%s' "${GIDEON_ORIG_SCRIPT:-${BASH_SOURCE[0]:-$0}}" | tr -d '\r')

    # If source is empty or just a basename, try $0
    if [[ -z "$source" ]] || [[ "$source" == "bash" ]]; then
        source="$0"
    fi

    # If still relative, make it absolute
    if [[ "$source" != /* ]]; then
        source="$(pwd)/$source"
    fi

    # Resolve symlinks
    while [[ -L "$source" ]]; do
        local link_dir
        link_dir=$(cd -P "$(dirname "$source")" 2>/dev/null && pwd)
        source=$(readlink "$source")
        if [[ "$source" != /* ]]; then
            source="$link_dir/$source"
        fi
    done

    local dir
    dir=$(cd -P "$(dirname "$source")" 2>/dev/null && pwd)
    printf '%s' "$dir"
}

GIDEON_SCRIPT_DIR=$(resolve_script_dir | tr -d '\r')

# ------------------------------------------------------------------------------
# Source all library modules
# Strip \r from sourced files for vboxsf compatibility
# ------------------------------------------------------------------------------
gideon_source() {
    # shellcheck disable=SC1090
    source <(tr -d '\r' < "$1")
}
gideon_source "$GIDEON_SCRIPT_DIR/lib/core.sh"
gideon_source "$GIDEON_SCRIPT_DIR/lib/platform.sh"
gideon_source "$GIDEON_SCRIPT_DIR/lib/ui.sh"
gideon_source "$GIDEON_SCRIPT_DIR/lib/validate.sh"
gideon_source "$GIDEON_SCRIPT_DIR/lib/backup.sh"
gideon_source "$GIDEON_SCRIPT_DIR/lib/ssh.sh"
gideon_source "$GIDEON_SCRIPT_DIR/lib/gitconfig.sh"
gideon_source "$GIDEON_SCRIPT_DIR/lib/guard.sh"
gideon_source "$GIDEON_SCRIPT_DIR/lib/verify.sh"
gideon_source "$GIDEON_SCRIPT_DIR/lib/teardown.sh"

# ------------------------------------------------------------------------------
# Signal trap — clean exit on Ctrl+C
# ------------------------------------------------------------------------------
cleanup() {
    printf >&2 '\n'
    print_warning "Interrupted. No changes were made (or partial changes were backed up)."
    exit 130
}
trap cleanup SIGINT SIGTERM

# ------------------------------------------------------------------------------
# Usage / Help text
# ------------------------------------------------------------------------------
show_help() {
    cat >&2 <<EOF
${BOLD}gideon${RESET} v${GIDEON_VERSION} — One command. All identities. Every machine.

${BOLD}USAGE${RESET}
    gideon setup [--dry-run]        Interactive setup wizard
    gideon status                   Show current identity configuration
    gideon verify                   Test SSH keys and git config
    gideon run <profile> -- <cmd>   Run command as specific identity
    gideon teardown [--force]       Remove all gideon configurations
    gideon guard --install          Install pre-commit identity guard hook
    gideon guard --uninstall        Remove the guard hook
    gideon --help, -h               Show this help
    gideon --version, -v            Show version

${BOLD}DESCRIPTION${RESET}
    gideon automates the setup of multiple Git identities and SSH keys.
    It generates Ed25519 SSH keys, creates ~/.gitconfig with conditional
    includes, sets up ~/.ssh/config host aliases, and verifies everything
    works — all in a single interactive session.

${BOLD}EXAMPLES${RESET}
    ${DIM}# First-time setup:${RESET}
    git clone https://github.com/bhaskarjha-com/gideon.git
    cd gideon
    ./gideon setup

    ${DIM}# Preview what setup would do:${RESET}
    ./gideon setup --dry-run

    ${DIM}# Check current identity:${RESET}
    ./gideon status

    ${DIM}# Run git as a specific profile:${RESET}
    ./gideon run work -- git commit -m "fix"

    ${DIM}# Install commit safety net:${RESET}
    ./gideon guard --install

${BOLD}MORE INFO${RESET}
    https://github.com/bhaskarjha-com/gideon
EOF
}

show_version() {
    printf 'gideon v%s\n' "$GIDEON_VERSION"
}

# ------------------------------------------------------------------------------
# cmd_status — Show current identity configuration
# ------------------------------------------------------------------------------
cmd_status() {
    detect_os

    print_header

    # Current directory info
    local cwd
    cwd=$(pwd)
    print_section "Current Directory"
    printf >&2 '  %s\n\n' "$cwd"

    # Current git identity
    local current_name current_email
    current_name=$(git config user.name 2>/dev/null || echo "(not set)")
    current_email=$(git config user.email 2>/dev/null || echo "(not set)")

    printf >&2 '  %b┌─ Active Identity ─────────────────────────────┐%b\n' "$BOLD" "$RESET"
    printf >&2 '  %b│%b  Name:  %b%s%b\n' "$DIM" "$RESET" "$CYAN" "${current_name}" "$RESET"
    printf >&2 '  %b│%b  Email: %b%s%b\n' "$DIM" "$RESET" "$CYAN" "${current_email}" "$RESET"
    
    # Check if inside a git repo
    if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        local ssh_cmd
        ssh_cmd=$(git config core.sshCommand 2>/dev/null || echo "(default)")
        printf >&2 '  %b│%b  SSH:   %b%s%b\n' "$DIM" "$RESET" "$GREEN" "${ssh_cmd}" "$RESET"
    fi
    printf >&2 '  %b└───────────────────────────────────────────────┘%b\n\n' "$DIM" "$RESET"

    # Show profile registry if it exists
    if [[ -f "$GIDEON_PROFILES_CONF" ]]; then
        print_section "Configured Profiles"

        while IFS=: read -r label email dir provider sign_commits key_path || [[ -n "$label" ]]; do
            [[ "$label" == "#"* ]] && continue
            [[ -z "$label" ]] && continue
            
            local dir_disp="${dir:-[Manual Mode]}"
            local prov_disp="${provider:-github.com}"
            
            # Check if this profile matches current identity
            local is_active="  "
            if [[ "$email" == "$current_email" ]]; then
                is_active="${GREEN}${SYM_CHECK} ${RESET}"
            fi
            
            printf >&2 '  %s%b%s%b\n' "$is_active" "$BOLD" "$label" "$RESET"
            printf >&2 '    %b├─%b %-9s %s\n' "$DIM" "$RESET" "Email:" "$email"
            printf >&2 '    %b├─%b %-9s %s\n' "$DIM" "$RESET" "Provider:" "$prov_disp"
            printf >&2 '    %b└─%b %-9s %s\n\n' "$DIM" "$RESET" "Path:" "$dir_disp"
        done < "$GIDEON_PROFILES_CONF"
    else
        print_info "No profiles configured. Run 'gideon setup' to get started."
    fi

    # Platform info
    print_section "Environment"
    printf >&2 '  OS:       %s\n' "$GIDEON_OS"
    printf >&2 '  Bash:     %s\n' "${BASH_VERSION:-unknown}"
    printf >&2 '  Git:      %s\n' "$(git --version 2>/dev/null | head -n1)"
    printf >&2 '  Config:   %s\n' "$GIDEON_CONFIG_DIR"
    printf >&2 '\n'
}

# ------------------------------------------------------------------------------
# cmd_verify — Run all verification checks
# ------------------------------------------------------------------------------
cmd_verify() {
    detect_os
    print_header

    # Load profiles from registry
    if [[ ! -f "$GIDEON_PROFILES_CONF" ]]; then
        print_error "No profiles configured. Run 'gideon setup' first."
        return 1
    fi

    # Read profiles from registry
    PROFILE_COUNT=0
    while IFS=: read -r label email dir provider sign_commits key_path || [[ -n "$label" ]]; do
        [[ "$label" == "#"* ]] && continue
        [[ -z "$label" ]] && continue
        PROFILE_LABELS+=("$label")
        PROFILE_EMAILS+=("$email")
        PROFILE_DIRS+=("$dir")
        PROFILE_PROVIDERS+=("${provider:-github.com}")
        PROFILE_SIGNS+=("${sign_commits:-0}")
        PROFILE_KEYS+=("${key_path:-~/.ssh/id_ed25519_${label}}")
        PROFILE_COUNT=$((PROFILE_COUNT + 1))
    done < "$GIDEON_PROFILES_CONF"

    if [[ "$PROFILE_COUNT" -eq 0 ]]; then
        print_error "No profiles found in registry. Run 'gideon setup' first."
        return 1
    fi

    verify_all
}

# ------------------------------------------------------------------------------
# cmd_teardown — Remove all gideon configurations
# ------------------------------------------------------------------------------
cmd_teardown() {
    detect_os
    print_header

    if [[ "$GIDEON_DRY_RUN" -eq 1 ]]; then
        print_info "DRY RUN MODE — no files will be written/deleted"
        printf >&2 '\n'
    fi

    local force="${1:-0}"

    if [[ "$force" -eq 0 ]] && [[ "$GIDEON_DRY_RUN" -eq 0 ]]; then
        print_warning "This will remove all Gideon configurations:"
        printf >&2 "  - Remove managed blocks from ~/.gitconfig\n"
        printf >&2 "  - Remove managed blocks from ~/.ssh/config\n"
        printf >&2 "  - Uninstall the commit guard hook\n"
        printf >&2 "  - Delete the ~/.config/gideon directory\n\n"
        if ! confirm "Are you sure you want to proceed?" "n"; then
            print_info "Teardown cancelled."
            return 0
        fi
    fi

    teardown_all
}

# ------------------------------------------------------------------------------
# cmd_setup — Interactive setup wizard
# ------------------------------------------------------------------------------
cmd_setup() {
    detect_os

    print_header

    if [[ "$GIDEON_DRY_RUN" -eq 1 ]]; then
        print_info "DRY RUN MODE — no files will be written"
        printf >&2 '\n'
    fi

    # --- Preflight ---
    print_section "Preflight Checks"
    printf >&2 '  OS detected: %b%s%b\n' "$BOLD" "$GIDEON_OS" "$RESET"

    if ! check_prerequisites; then
        return 1
    fi
    print_success "All prerequisites met"

    # Check for shared folder
    if is_shared_mount "$HOME" 2>/dev/null; then
        print_warning "Home directory appears to be on a shared folder."
        print_info "SSH keys will be stored on the native filesystem at ~/.ssh"
    fi

    # --- Collect profiles ---
    print_section "Profile Configuration"
    print_info "A profile defines a Git identity (name, email, SSH key)."
    print_info "The first profile will be your default/global identity."
    printf >&2 '\n'

    # Ask how many profiles
    ask_count "How many profiles do you need?" 1 10
    local num_profiles="$REPLY"

    local i
    for i in $(seq 1 "$num_profiles"); do
        print_section "Profile $i of $num_profiles"

        # Label
        if [[ "$i" -eq 1 ]]; then
            print_info "This is your DEFAULT profile (used when no directory rule matches)."
            ask "Profile label" "global"
        else
            ask_required "Profile label (e.g., pro, work, oss)"
        fi
        local label
        label=$(to_lower "$REPLY")

        # Validate label
        while ! validate_label "$label"; do
            print_warning "Label must be lowercase letters, numbers, and hyphens (1-20 chars, starts with letter)."
            ask_required "Profile label"
            label=$(to_lower "$REPLY")
        done

        # Check for duplicate
        while array_contains "$label" "${PROFILE_LABELS[@]+"${PROFILE_LABELS[@]}"}"; do
            print_warning "Label '$label' already used. Choose a different one."
            ask_required "Profile label"
            label=$(to_lower "$REPLY")
        done

        # Name
        local default_name=""
        if [[ "$i" -eq 1 ]]; then
            default_name=$(git config --global user.name 2>/dev/null || echo "")
        fi
        ask "Full name" "$default_name"
        local name="$REPLY"
        if [[ -z "$name" ]]; then
            ask_required "Full name"
            name="$REPLY"
        fi

        # Provider
        printf >&2 '\n  %bGit Provider%b\n' "$BOLD" "$RESET"
        printf >&2 '  1) GitHub (github.com)\n'
        printf >&2 '  2) GitLab (gitlab.com)\n'
        printf >&2 '  3) Bitbucket (bitbucket.org)\n'
        printf >&2 '  4) Custom (Self-Hosted)\n'
        ask "Select provider [1-4]" "1"
        local provider_choice="$REPLY"
        local provider="github.com"
        case "$provider_choice" in
            2) provider="gitlab.com" ;;
            3) provider="bitbucket.org" ;;
            4)
                ask "Custom domain (e.g., git.company.com)" ""
                provider="$REPLY"
                while [[ -z "$provider" ]]; do
                    ask_required "Custom domain"
                    provider="$REPLY"
                done
                ;;
        esac

        # Email
        local default_email=""
        if [[ "$i" -eq 1 ]]; then
            default_email=$(git config --global user.email 2>/dev/null || echo "")
        fi
        
        local valid_email=0
        local email=""

        while [[ "$valid_email" -eq 0 ]]; do
            ask_email "Email address" "$default_email"
            email="$REPLY"

            if [[ "$provider" == "github.com" ]] && ! validate_github_noreply_email "$email"; then
                printf >&2 '\n'
                print_warning "For privacy, GitHub recommends using your masked noreply email:"
                print_warning "Format: ID+username@users.noreply.github.com"
                if confirm "Use this email anyway?" "n"; then
                    valid_email=1
                fi
            else
                valid_email=1
            fi
        done


        # Directory (not needed for default profile — it's the fallback)
        local dir=""
        if [[ "$i" -gt 1 ]]; then
            ask_path "Directory for this profile (e.g., ~/dev/work) [Optional]" ""
            dir="$REPLY"
            
            if [[ -z "$dir" ]]; then
                print_info "No directory provided. This profile will run in Manual Mode (host alias only)."
            else
                # Validate no overlap
                if ! validate_no_overlap "$dir" "${PROFILE_DIRS[@]+"${PROFILE_DIRS[@]}"}"; then
                    print_warning "Directory '$dir' overlaps with an existing profile."
                    print_info "Git uses the last matching includeIf, so overlaps can cause confusion."
                    if ! confirm "Continue anyway?" "n"; then
                        print_info "Skipping this profile."
                        continue
                    fi
                fi
            fi
        fi

        # SSH Commit Signing
        local sign_commits="0"
        if confirm "Enable Native SSH Commit Signing for this profile (Git 2.34+ required)?" "Y"; then
            sign_commits="1"
        fi

        # SSH Key Path / Generation
        local key_path=""
        ask "Path to existing SSH key (Press Enter to generate a new one)" ""
        if [[ -n "$REPLY" ]]; then
            key_path=$(normalize_path "$REPLY")
        else
            if confirm "Use a FIDO2 Hardware Security Key (e.g., YubiKey) for this profile?" "n"; then
                key_path="~/.ssh/id_ed25519_sk_${label}"
            else
                key_path="~/.ssh/id_ed25519_${label}"
            fi
        fi

        # Store profile
        PROFILE_LABELS+=("$label")
        PROFILE_NAMES+=("$name")
        PROFILE_EMAILS+=("$email")
        PROFILE_DIRS+=("$dir")
        PROFILE_PROVIDERS+=("$provider")
        PROFILE_SIGNS+=("$sign_commits")
        PROFILE_KEYS+=("$key_path")
        PROFILE_COUNT=$((PROFILE_COUNT + 1))

        print_success "Profile '$label' configured: $name <$email>"
    done

    # Global Passphrase
    printf >&2 '\n'
    print_section "SSH Security"
    print_info "Gideon can generate password-less SSH keys (convenient) or"
    print_info "protect them with a passphrase (secure). If you choose secure,"
    print_info "ssh-keygen will interactively prompt you for a passphrase."
    if confirm "Protect new SSH keys with a passphrase?" "n"; then
        export GIDEON_USE_PASSPHRASE=1
    fi

    # --- Review plan ---
    print_section "Setup Plan"
    printf >&2 '  The following will be created/updated:\n\n'

    for i in $(seq 0 $((PROFILE_COUNT - 1))); do
        local label="${PROFILE_LABELS[$i]}"
        local name="${PROFILE_NAMES[$i]}"
        local email="${PROFILE_EMAILS[$i]}"
        local dir="${PROFILE_DIRS[$i]}"
        local provider="${PROFILE_PROVIDERS[$i]}"

        if [[ "$i" -eq "$DEFAULT_PROFILE_INDEX" ]]; then
            printf >&2 '  %b%s%b (default)\n' "$BOLD" "$label" "$RESET"
        else
            printf >&2 '  %b%s%b → %s\n' "$BOLD" "$label" "$RESET" "${dir:-[Manual Mode]}"
        fi
        printf >&2 '    Name:     %s\n' "$name"
        printf >&2 '    Email:    %s\n' "$email"
        printf >&2 '    Provider: %s\n' "$provider"
        printf >&2 '    Key:      %s\n\n' "${PROFILE_KEYS[$i]:-~/.ssh/id_ed25519_${label}}"
    done

    printf >&2 '  %bFiles:%b\n' "$BOLD" "$RESET"
    printf >&2 '    %s SSH key pairs\n' "$PROFILE_COUNT"
    printf >&2 '    ~/.gitconfig (global config with includeIf rules)\n'
    printf >&2 '    %d profile config(s) in %s\n' "$((PROFILE_COUNT - 1))" "$GIDEON_PROFILES_DIR"
    printf >&2 '    ~/.ssh/config (host aliases for cloning)\n'
    printf >&2 '\n'

    if [[ "$GIDEON_DRY_RUN" -eq 1 ]]; then
        print_info "DRY RUN — showing what would be generated:"
        printf >&2 '\n'
    else
        if ! confirm "Proceed with setup?" "y"; then
            print_info "Setup cancelled. No changes made."
            return 0
        fi
    fi

    # --- Execute setup ---
    ensure_dirs

    # 1. Generate SSH keys
    print_section "Generating SSH Keys"
    for i in $(seq 0 $((PROFILE_COUNT - 1))); do
        local key_path="${PROFILE_KEYS[$i]}"
        # If user provided a custom path and it exists, or if it was generated before, skip generation if not _sk_
        # Actually, let generate_ssh_key handle the "file exists" prompt, but we skip if they specifically entered a custom path in the prompt
        # Wait, how do we know if it was custom? If it doesn't match the default pattern.
        # But generate_ssh_key already checks if -f exists and prompts. We just pass the key_path.
        generate_ssh_key "${PROFILE_LABELS[$i]}" "${PROFILE_EMAILS[$i]}" "$key_path"
        if [[ $? -ne 0 ]] && [[ "$key_path" == *"_sk_"* ]]; then
            print_warning "FIDO2 Hardware Key generation failed."
            print_info "This usually means libfido2 is missing from your OS, or no token was touched."
            if confirm "Fallback to standard software SSH key for '${PROFILE_LABELS[$i]}'?" "y"; then
                key_path="$HOME/.ssh/id_ed25519_${PROFILE_LABELS[$i]}"
                PROFILE_KEYS[$i]="$key_path"
                generate_ssh_key "${PROFILE_LABELS[$i]}" "${PROFILE_EMAILS[$i]}" "$key_path"
            else
                print_error "Setup aborted due to FIDO2 key generation failure."
                return 1
            fi
        fi
    done

    # 2. Write profile gitconfigs (for non-default profiles)
    print_section "Writing Git Configuration"
    for i in $(seq 0 $((PROFILE_COUNT - 1))); do
        if [[ "$i" -ne "$DEFAULT_PROFILE_INDEX" ]]; then
            write_profile_gitconfig "${PROFILE_LABELS[$i]}" "${PROFILE_NAMES[$i]}" "${PROFILE_EMAILS[$i]}" "${PROFILE_SIGNS[$i]}" "${PROFILE_KEYS[$i]}"
        fi
    done

    # 3. Write global gitconfig
    write_global_gitconfig

    # 4. Write SSH config
    print_section "Updating SSH Configuration"
    write_ssh_config

    # 5. Write profiles registry
    write_profiles_conf

    # 6. Display public keys
    if [[ "$GIDEON_DRY_RUN" -eq 0 ]]; then
        display_public_keys
    fi

    # 7. Offer guard hook
    if [[ "$GIDEON_DRY_RUN" -eq 0 ]]; then
        print_section "Identity Guard Hook"
        print_info "gideon can install a pre-commit hook that warns if you're"
        print_info "about to commit with the wrong identity for a directory."
        printf >&2 '\n'

        if confirm "Install the identity guard hook?" "y"; then
            install_guard
        else
            print_info "Skipped. You can install later with: gideon guard --install"
        fi
    fi

    # 8. Show next steps
    print_section "Next Steps"
    printf >&2 '  %b1.%b Add your public keys to GitHub/GitLab (see above)\n' "$BOLD" "$RESET"
    printf >&2 '     → %bhttps://github.com/settings/ssh/new%b\n\n' "$CYAN" "$RESET"

    printf >&2 '  %b2.%b Test SSH connectivity:\n' "$BOLD" "$RESET"
    for i in $(seq 0 $((PROFILE_COUNT - 1))); do
        printf >&2 '     ssh -T git@github-%s\n' "${PROFILE_LABELS[$i]}"
    done
    printf >&2 '\n'

    printf >&2 '  %b3.%b Magical Clone! Just cd into your profile directory and clone normally:\n' "$BOLD" "$RESET"
    printf >&2 '     cd /path/to/profile/dir\n'
    printf >&2 '     git clone git@github.com:username/repo.git\n'
    printf >&2 '\n'

    printf >&2 '  %b4.%b Verify your setup:\n' "$BOLD" "$RESET"
    printf >&2 '     ./gideon verify\n\n'

    # SSH agent advice
    print_section "SSH Agent Setup"
    get_ssh_agent_advice
    printf >&2 '\n'

    print_success "Setup complete! You're ready to go."
    printf >&2 '\n'
}

# ------------------------------------------------------------------------------
# cmd_run — Execute a command under a specific profile identity
# ------------------------------------------------------------------------------
cmd_run() {
    detect_os
    local profile="$1"
    shift
    
    if [[ -z "$profile" ]]; then
        print_error "Usage: gideon run <profile> -- <command>"
        return 1
    fi
    
    if [[ "$1" == "--" ]]; then shift; fi
    
    if [[ $# -eq 0 ]]; then
        print_error "No command provided. Usage: gideon run <profile> -- <command>"
        return 1
    fi
    
    # Check if profile exists
    if [[ ! -f "$GIDEON_PROFILES_CONF" ]]; then
        print_error "No profiles configured. Run 'gideon setup' first."
        return 1
    fi

    local found=0
    local found_key_path=""
    while IFS=: read -r label email dir provider sign_commits key_path || [[ -n "$label" ]]; do
        if [[ "$label" == "$profile" ]]; then
            found=1
            found_key_path="${key_path:-~/.ssh/id_ed25519_${label}}"
            break
        fi
    done < "$GIDEON_PROFILES_CONF"
    
    if [[ "$found" -eq 0 ]]; then
        print_error "Profile '$profile' not found in registry."
        return 1
    fi
    
    local name email
    local config_file="$GIDEON_PROFILES_DIR/${profile}.gitconfig"
    
    if [[ ! -f "$config_file" ]]; then
        # Global profile (stored in ~/.gitconfig)
        name=$(git config --global user.name 2>/dev/null || echo "")
        email=$(git config --global user.email 2>/dev/null || echo "")
    else
        name=$(git config -f "$config_file" user.name 2>/dev/null || echo "")
        email=$(git config -f "$config_file" user.email 2>/dev/null || echo "")
    fi
    
    export GIT_AUTHOR_NAME="$name"
    export GIT_AUTHOR_EMAIL="$email"
    export GIT_COMMITTER_NAME="$name"
    export GIT_COMMITTER_EMAIL="$email"
    export GIT_SSH_COMMAND="ssh -i ${found_key_path}"
    
    exec "$@"
}

# ------------------------------------------------------------------------------
# cmd_remove — Surgically remove a single profile
# ------------------------------------------------------------------------------
cmd_remove() {
    detect_os
    local profile="$1"
    
    if [[ -z "$profile" ]]; then
        print_error "Usage: gideon remove <profile>"
        return 1
    fi
    
    if [[ ! -f "$GIDEON_PROFILES_CONF" ]]; then
        print_error "No profiles configured."
        return 1
    fi
    
    # Check if profile exists
    local found=0
    local found_key_path=""
    while IFS=: read -r label email dir provider sign_commits key_path || [[ -n "$label" ]]; do
        if [[ "$label" == "$profile" ]]; then
            found=1
            found_key_path="${key_path:-~/.ssh/id_ed25519_${label}}"
            break
        fi
    done < "$GIDEON_PROFILES_CONF"
    
    if [[ "$found" -eq 0 ]]; then
        print_error "Profile '$profile' not found."
        return 1
    fi

    if ! confirm "Are you sure you want to completely remove profile '$profile'?" "n"; then
        print_info "Cancelled."
        return 0
    fi
    
    print_step "Removing profile '$profile'..."
    
    # 1. Remove from profiles.conf using awk (sed is non-portable across BSD/GNU without weird syntax)
    local tmp_conf
    tmp_conf=$(mktemp "${GIDEON_PROFILES_CONF}.tmp.XXXXXX")
    awk -F: -v prof="$profile" '$1 != prof {print}' "$GIDEON_PROFILES_CONF" > "$tmp_conf"
    mv "$tmp_conf" "$GIDEON_PROFILES_CONF"
    
    # 2. Delete the profile gitconfig
    local config_file="$GIDEON_PROFILES_DIR/${profile}.gitconfig"
    if [[ -f "$config_file" ]]; then
        rm -f "$config_file"
    fi
    
    # 3. Reload in-memory arrays so the writers have the updated state
    PROFILE_LABELS=()
    PROFILE_NAMES=()
    PROFILE_EMAILS=()
    PROFILE_DIRS=()
    PROFILE_PROVIDERS=()
    PROFILE_SIGNS=()
    PROFILE_COUNT=0
    
    while IFS=: read -r label email dir provider sign_commits key_path || [[ -n "$label" ]]; do
        [[ "$label" == "#"* ]] && continue
        [[ -z "$label" ]] && continue
        PROFILE_LABELS+=("$label")
        PROFILE_EMAILS+=("$email")
        PROFILE_DIRS+=("$dir")
        PROFILE_PROVIDERS+=("${provider:-github.com}")
        PROFILE_SIGNS+=("${sign_commits:-0}")
        PROFILE_KEYS+=("${key_path:-~/.ssh/id_ed25519_${label}}")
        PROFILE_COUNT=$((PROFILE_COUNT + 1))
    done < "$GIDEON_PROFILES_CONF"
    
    # Note: We do not reload PROFILE_NAMES from the conf because we never stored them there!
    # Wait, write_global_gitconfig relies on PROFILE_NAMES for the default profile...
    # BUT wait! We deleted the default profile's name/email injection in step 1 of the audit fix!
    # The default profile only needs the label to set sshCommand! It NO LONGER needs PROFILE_NAMES.
    
    # 4. Re-run block generators (idempotent, they will overwrite the global configs without the removed profile)
    write_global_gitconfig >/dev/null
    write_ssh_config >/dev/null
    
    print_success "Profile '$profile' successfully removed."
    
    # Ask about SSH keys
    local key_file="${found_key_path}"
    if [[ -f "$key_file" ]]; then
        printf >&2 '\n'
        print_warning "SSH keys for '$profile' still exist:"
        print_info "  $key_file"
        print_info "  $key_file.pub"
        if confirm "Delete these SSH keys permanently?" "n"; then
            rm -f "$key_file" "$key_file.pub"
            print_success "SSH keys deleted."
        else
            print_info "Keys kept. You can manually delete them later."
        fi
    fi
}

# ------------------------------------------------------------------------------
# cmd_init — Profile-Aware Scaffolder & Retrofitter
# ------------------------------------------------------------------------------
cmd_init() {
    local target_profile=""
    if [[ "$1" == "--profile" ]]; then
        target_profile="$2"
        shift 2
    fi

    # 1. Detect profile
    local active_profile=""
    if [[ -n "$target_profile" ]]; then
        active_profile="$target_profile"
        # Verify it exists
        local found=0
        while IFS=: read -r label email dir provider sign_commits key_path || [[ -n "$label" ]]; do
            if [[ "$label" == "$active_profile" ]]; then found=1; break; fi
        done < "$GIDEON_PROFILES_CONF"
        if [[ "$found" -eq 0 ]]; then
            print_error "Profile '$active_profile' not found."
            return 1
        fi
    else
        # Detect from PWD
        active_profile=$(cmd_prompt)
        if [[ -z "$active_profile" ]]; then
            print_error "Current directory does not match any Gideon profile path."
            print_info "Provide a profile explicitly: gideon init --profile <name>"
            return 1
        fi
    fi

    # 2. Run git init
    if [[ ! -d ".git" ]]; then
        print_step "Initializing git repository..."
        git init -q
    else
        print_step "Repository already initialized."
    fi

    # 3. Scaffold Templates (if empty)
    # Only copy templates if the repo is empty (no commits yet) to avoid overwriting existing files
    if ! git rev-parse HEAD >/dev/null 2>&1; then
        local template_dir="$HOME/.config/gideon/templates/$active_profile"
        if [[ -d "$template_dir" ]]; then
            print_step "Applying templates for profile '$active_profile'..."
            cp -n "$template_dir"/* . 2>/dev/null || true
            cp -n "$template_dir"/.* . 2>/dev/null || true
        fi
    fi

    # 4. Retrofit (If explicitly requested via --profile, we inject local configs to bypass includeIf)
    if [[ -n "$target_profile" ]]; then
        print_step "Retrofitting repository to enforce profile '$active_profile'..."
        # Get profile details
        local p_name p_email p_key
        local config_file="$GIDEON_PROFILES_DIR/${active_profile}.gitconfig"
        if [[ -f "$config_file" ]]; then
            p_name=$(git config -f "$config_file" user.name)
            p_email=$(git config -f "$config_file" user.email)
            p_key=$(git config -f "$config_file" core.sshCommand)
            
            git config --local user.name "$p_name"
            git config --local user.email "$p_email"
            git config --local core.sshCommand "$p_key"
            print_success "Local overrides injected into .git/config"
        else
            print_error "Could not find gitconfig for profile '$active_profile'."
            return 1
        fi
    fi

    print_success "Repository initialized for identity '$active_profile'."
}

# ------------------------------------------------------------------------------
# cmd_prompt — Zero-latency profile detection for PS1 integration
# ------------------------------------------------------------------------------
cmd_prompt() {
    if [[ ! -f "$GIDEON_PROFILES_CONF" ]]; then
        return 0
    fi

    # Normalize PWD like we do for dirs
    local current_pwd="${PWD%/}"
    
    local matched_profile=""
    local max_len=0

    # Prefix match without subshells
    while IFS=: read -r label email dir provider sign_commits key_path || [[ -n "$label" ]]; do
        [[ -z "$dir" ]] && continue
        
        # Check if PWD starts with the profile dir
        if [[ "$current_pwd/" == "$dir/"* ]] || [[ "$current_pwd" == "$dir" ]]; then
            # Longest match wins
            local dir_len=${#dir}
            if [[ "$dir_len" -gt "$max_len" ]]; then
                max_len=$dir_len
                matched_profile="$label"
            fi
        fi
    done < "$GIDEON_PROFILES_CONF"

    if [[ -n "$matched_profile" ]]; then
        echo "$matched_profile"
    fi
}

# ------------------------------------------------------------------------------
# Main — Parse arguments and route to subcommand
# ------------------------------------------------------------------------------
main() {
    # No arguments → show brief usage
    if [[ $# -eq 0 ]]; then
        printf >&2 '%bgideon%b v%s — One command. All identities. Every machine.\n\n' \
            "$BOLD" "$RESET" "$GIDEON_VERSION"
        printf >&2 'Usage: gideon setup [--dry-run]    Start the setup wizard\n'
        printf >&2 '       gideon status               Show current identity\n'
        printf >&2 '       gideon verify               Test SSH and git config\n'
        printf >&2 '       gideon init [--profile <name>] Scaffolds/retrofits a repo\n'
        printf >&2 '       gideon prompt               Print active profile (for PS1)\n'
        printf >&2 '       gideon run <profile> -- <cmd>  Run as identity\n'
        printf >&2 '       gideon remove <profile>     Remove a specific profile\n'
        printf >&2 '       gideon teardown [--force]   Remove all configurations\n'
        printf >&2 '       gideon guard --install      Install commit guard hook\n'
        printf >&2 '       gideon --help                Full help\n\n'
        return 0
    fi

    local cmd="$1"
    shift

    case "$cmd" in
        setup)
            # Parse setup flags
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --dry-run)
                        GIDEON_DRY_RUN=1
                        shift
                        ;;
                    *)
                        print_error "Unknown flag: $1"
                        printf >&2 'Usage: gideon setup [--dry-run]\n'
                        return 1
                        ;;
                esac
            done
            cmd_setup
            ;;
        status)
            cmd_status
            ;;
        verify)
            cmd_verify
            ;;
        run)
            if [[ $# -lt 1 ]]; then
                print_error "Usage: gideon run <profile> -- <command>"
                return 1
            fi
            cmd_run "$@"
            ;;
        remove)
            cmd_remove "$1"
            ;;
        init)
            cmd_init "$@"
            ;;
        prompt)
            cmd_prompt "$@"
            ;;
        teardown)
            local force=0
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --dry-run) GIDEON_DRY_RUN=1 ;;
                    --force|-f) force=1 ;;
                    *)
                        print_error "Unknown flag: $1"
                        printf >&2 'Usage: gideon teardown [--dry-run] [--force]\n'
                        return 1
                        ;;
                esac
                shift
            done
            cmd_teardown "$force"
            ;;
        guard)
            if [[ $# -eq 0 ]]; then
                print_error "Usage: gideon guard --install | --uninstall"
                return 1
            fi
            case "$1" in
                --install)   detect_os; install_guard ;;
                --uninstall) detect_os; uninstall_guard ;;
                *)
                    print_error "Unknown flag: $1"
                    printf >&2 'Usage: gideon guard --install | --uninstall\n'
                    return 1
                    ;;
            esac
            ;;
        --help|-h|help)
            show_help
            ;;
        --version|-v)
            show_version
            ;;
        *)
            print_error "Unknown command: $cmd"
            printf >&2 'Run "gideon --help" for usage.\n'
            return 1
            ;;
    esac
}

main "$@"
